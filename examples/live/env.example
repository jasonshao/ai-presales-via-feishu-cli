# Live mode environment for the Feishu CLI AI Presales Skill.
# Copy this file to a private location (NEVER commit) and fill in real values.
#
#   cp examples/live/env.example ~/.presales.env
#   chmod 600 ~/.presales.env
#   set -a; source ~/.presales.env; set +a
#
# Tokens are read from a Feishu Bitable. Use a DEMO Bitable until you are
# certain about the data flow — do not point this at a production presales
# Bitable until the agent has been reviewed end-to-end.

# Bitable app token (the long string in the Bitable URL after /base/)
PRESALES_BASE_TOKEN=

# Table ids for each presales table. Get them via:
#   lark-cli base +table-list --base-token "$PRESALES_BASE_TOKEN" --format json
PRESALES_REPORT_TABLE=
PRESALES_SCENARIO_TABLE=
PRESALES_CAPABILITY_TABLE=
PRESALES_CASE_TABLE=
PRESALES_STATUS_TABLE=

# Feishu Drive folder token used for generated solution drafts.
# Use a DEMO folder. Never use a customer-facing folder without explicit
# approval each time.
PRESALES_OUTPUT_FOLDER_TOKEN=

# Optional: Wiki/Docx token for a decision-guide doc the agent can consult.
PRESALES_DECISION_GUIDE_DOC=
